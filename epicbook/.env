# ─────────────────────────────────────────────
# EpicBook Docker Compose Environment
# DO NOT COMMIT THIS FILE TO GIT
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NODE_ENV=production
APP_PORT=8080

# ── MySQL Container ───────────────────────────
MYSQL_ROOT_PASSWORD=RootPass@MySQL123
MYSQL_DATABASE=bookstore
MYSQL_USER=epicbookadmin
MYSQL_PASSWORD=EpicBook@MySQL123

# ── App DB Connection (used by entrypoint) ────
DB_HOST=mysql
DB_PORT=3306
DB_NAME=bookstore
DB_USER=epicbookadmin
DB_PASSWORD=EpicBook@MySQL123
